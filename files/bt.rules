# shellcheck shell=bash
eout "{glob} loading bt.rules"

# Load our Deny Hosts rules
glob_deny_download
deny_hosts $GDENY_HOSTS TGDENY
deny_hosts $DENY_HOSTS TDENY

# Load our projecthoneypot drop list
dlist_php
dlist_php_hosts

# Load our dshield drop list
dlist_dshield
dlist_dshield_hosts

# Load our Spamhaus Don't Route Or Peer List
dlist_spamhaus
dlist_spamhaus_hosts

# Load ipset block lists
ipset_load

# Block common drop ports
cdports

# Filter all traffic not from local gateway
if [ -n "$VF_LGATE" ]; then
 lgate_mac
fi

if [ "$RAB" == "1" ] && [ "$RAB_SANITY" == "1" ]; then
	eout "{rab} set active RAB_SANITY"
	RAB_SANITY_FLAGS="-m recent --set"
else
	RAB_SANITY_FLAGS=""
fi
if [ "$PKT_SANITY" == "1" ]; then
	eout "{pkt_sanity} set active PKT_SANITY"

	# Helper: create INVALID state + tcp-option rules for a sanity chain pair
	# Args: ipt_fn in_chain out_chain prefix include_tcp_opts rab_extra
	_sanity_inv_rules() {
		local ipt_fn="$1" in_chain="$2" out_chain="$3" prefix="$4"
		local include_tcp_opts="$5" rab_extra="$6"
		_log_drop "$ipt_fn" "$in_chain" "-m state --state INVALID" "** $prefix ** " "$ALL_STOP" "$rab_extra"
		if [ "$include_tcp_opts" == "1" ]; then
			_log_drop "$ipt_fn" "$in_chain" "-p tcp --tcp-option 64" "** $prefix ** " "$TCP_STOP"
			_log_drop "$ipt_fn" "$in_chain" "-p tcp --tcp-option 128" "** $prefix ** " "$TCP_STOP"
		fi
		_log_drop "$ipt_fn" "$out_chain" "-m state --state INVALID" "** $prefix ** " "$ALL_STOP"
	}

	# Helper: create port-zero blocking rules for a chain
	# Args: ipt_fn chain prefix
	_pzero_rules() {
		local ipt_fn="$1" chain="$2" prefix="$3"
		_log_drop "$ipt_fn" "$chain" "-p tcp --dport 0" "** $prefix ** " "$TCP_STOP" "$RAB_SANITY_FLAGS"
		_log_drop "$ipt_fn" "$chain" "-p udp --dport 0" "** $prefix ** " "$UDP_STOP" "$RAB_SANITY_FLAGS"
		_log_drop "$ipt_fn" "$chain" "-p tcp --sport 0" "** $prefix ** " "$TCP_STOP" "$RAB_SANITY_FLAGS"
		_log_drop "$ipt_fn" "$chain" "-p udp --sport 0" "** $prefix ** " "$UDP_STOP" "$RAB_SANITY_FLAGS"
	}

	# Helper: create fragmented UDP chain
	# Args: ipt_fn chain frag_match log_prefix rab_prefix
	# shellcheck disable=SC2086
	_frag_udp_rules() {
		local ipt_fn="$1" chain="$2" frag_match="$3" log_prefix="$4" rab_prefix="$5"
		$ipt_fn -N "$chain"
		if [ "$LOG_DROP" == "1" ]; then
			$ipt_fn -A "$chain" -p udp $frag_match -m limit --limit=$LOG_RATE/minute \
				-j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "$log_prefix"
		fi
		_rab_log "$ipt_fn" "$chain" "-p udp $frag_match" "$rab_prefix"
		$ipt_fn -A "$chain" -p udp $frag_match $RAB_SANITY_FLAGS -j $UDP_STOP
		$ipt_fn -A INPUT -j "$chain"
		$ipt_fn -A OUTPUT -j "$chain"
	}

	# IPv4 sanity chains
	eout "{pkt_sanity} deny inbound tcp-flag pairs (11 pairs)"
	ipt4 -N IN_SANITY
	pkt_sanity_flags IN_SANITY ipt4 "SANITY" "RABHIT" 1

	eout "{pkt_sanity} deny outbound tcp-flag pairs (11 pairs)"
	ipt4 -N OUT_SANITY
	pkt_sanity_flags OUT_SANITY ipt4 "SANITY" "" 0

	if [ "$PKT_SANITY_INV" == "1" ]; then
		eout "{pkt_sanity} check inbound/outbound for INVALID states"
		eout "{pkt_sanity} deny inbound tcp-option 64/128"
		_sanity_inv_rules ipt4 IN_SANITY OUT_SANITY "SANITY" 1 ""
	fi

	ipt4 -A OUTPUT -j OUT_SANITY
	ipt4 -A INPUT -j IN_SANITY

	# IPv6 sanity chains
	if [ "$USE_IPV6" == "1" ]; then
		eout "{pkt_sanity} set active PKT_SANITY (IPv6)"
		ipt6 -N IN_SANITY6
		pkt_sanity_flags IN_SANITY6 ipt6 "SANITY6" "RABHIT6" 1

		ipt6 -N OUT_SANITY6
		pkt_sanity_flags OUT_SANITY6 ipt6 "SANITY6" "" 0

		if [ "$PKT_SANITY_INV" == "1" ]; then
			# IPv6 INVALID uses RAB_SANITY_FLAGS on inbound; no tcp-option rules
			_sanity_inv_rules ipt6 IN_SANITY6 OUT_SANITY6 "SANITY6" 0 "$RAB_SANITY_FLAGS"
		fi

		ipt6 -A INPUT -j IN_SANITY6
		ipt6 -A OUTPUT -j OUT_SANITY6
	fi

	# Fragmented UDP blocking
	if [ "$PKT_SANITY_FUDP" == "1" ]; then
		eout "{pkt_sanity} deny all fragmented udp"
		_frag_udp_rules ipt4 FRAG_UDP "-f" "** UDP Frag ** " "** RABHIT ** "
		if [ "$USE_IPV6" == "1" ]; then
			eout "{pkt_sanity} deny all fragmented ipv6 udp"
			_frag_udp_rules ipt6 FRAG_UDP6 "-m frag --fragmore" "** UDP6 Frag ** " "** RABHIT6 ** "
		fi
	fi

	# Port zero blocking
	if [ "$PKT_SANITY_PZERO" == "1" ]; then
		eout "{pkt_sanity} deny port zero traffic"
		ipt4 -N PZERO
		_pzero_rules ipt4 PZERO "Port Zero"
		ipt4 -A INPUT -j PZERO
		ipt4 -A OUTPUT -j PZERO
		if [ "$USE_IPV6" == "1" ]; then
			ipt6 -N PZERO6
			_pzero_rules ipt6 PZERO6 "PortZero6"
			ipt6 -A INPUT -j PZERO6
			ipt6 -A OUTPUT -j PZERO6
		fi
	fi
fi

# SYN flood protection — rate limit inbound TCP SYN packets
if [ "$SYNFLOOD" == "1" ]; then
	eout "{synflood} set active SYNFLOOD"
	eout "{synflood} rate limit inbound SYN to $SYNFLOOD_RATE burst $SYNFLOOD_BURST"
	ipt -N SYNFLOOD
	ipt -A SYNFLOOD -p tcp --syn -m limit --limit=$SYNFLOOD_RATE --limit-burst=$SYNFLOOD_BURST -j RETURN
	_log_drop ipt SYNFLOOD "-p tcp --syn" "** SYNFLOOD ** " "$TCP_STOP"
	ipt -A INPUT -j SYNFLOOD
fi

if [ "$BLK_IDENT" = "1" ]; then
	eout "{blk_ident} set active BLK_IDENT"
	# Reject ident request if not defined in IG_TCP_CPORTS
	if [[ ",$IG_TCP_CPORTS," != *,113,* ]]; then
		eout "{blk_ident} reject all to/from tcp port 113"
		ipt -N IDENT
		_log_drop ipt IDENT "-p tcp --dport 113" "** IDENT ** " "REJECT"
		_log_drop ipt IDENT "-p tcp --sport 113" "** IDENT ** " "REJECT"
		_log_drop ipt IDENT "-p udp --dport 113" "** IDENT ** " "REJECT"
		_log_drop ipt IDENT "-p udp --sport 113" "** IDENT ** " "REJECT"
		ipt -A INPUT -j IDENT
		ipt -A OUTPUT -j IDENT
	fi
fi

if [ "$BLK_MCATNET" == "1" ]; then
	eout "{blk_mcat} set active BLK_MCATNET"
	# Block Multicast
	eout "{blk_mcat} deny all from 224.0.0.0/8"
	eout "{blk_mcat} deny all to 224.0.0.0/8"
	ipt4 -N MCAST
	_log_drop ipt4 MCAST "-s 224.0.0.0/8" "** MCAST ** " "$ALL_STOP"
	_log_drop ipt4 MCAST "-d 224.0.0.0/8" "** MCAST ** " "$ALL_STOP"
	ipt4 -A INPUT -j MCAST
	ipt4 -A OUTPUT -j MCAST

	# IPv6 multicast blocking (ff00::/8)
	# NDP (types 133-136) uses multicast destinations (ff02::) and must be
	# exempted or IPv6 neighbor discovery breaks silently.
	if [ "$USE_IPV6" == "1" ]; then
		eout "{blk_mcat} deny all from ff00::/8 (IPv6)"
		eout "{blk_mcat} deny all to ff00::/8 (IPv6)"
		ipt6 -N MCAST6
		# Exempt NDP — these use ff02:: multicast destinations
		for t in $NDP_TYPES; do
			ipt6 -A MCAST6 -p ipv6-icmp --icmpv6-type $t -j RETURN
		done
		_log_drop ipt6 MCAST6 "-s ff00::/8" "** MCAST6 ** " "$ALL_STOP"
		_log_drop ipt6 MCAST6 "-d ff00::/8" "** MCAST6 ** " "$ALL_STOP"
		ipt6 -A INPUT -j MCAST6
		ipt6 -A OUTPUT -j MCAST6
	fi
fi

if [ -n "$BLK_P2P_PORTS" ]; then
        eout "{blk_p2p} set active BLK_P2P"
        # Drop traffic to/from common p2p ports
        ipt -N P2P
        for i in ${BLK_P2P_PORTS//,/ }; do
                PORT=$i
                if [[ "$i" != *_* ]]; then
                        eout "{blk_p2p} deny all to/from tcp port $i"
                        eout "{blk_p2p} deny all to/from udp port $i"
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p tcp --sport 1024:65534 --dport $PORT -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p tcp --dport $PORT -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p tcp --dport 1024:65534 --sport $PORT -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p tcp --dport 1024:65534 --sport $PORT -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p udp --sport 1024:65534 --dport $PORT -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p udp --sport 1024:65534 --dport $PORT -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p udp --dport 1024:65534 --sport $PORT -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p udp --dport 1024:65534 --sport $PORT -j REJECT
                else
                        expand_port "$i"; PORTST="$_PORT"
                        eout "{blk_p2p} deny all to/from tcp port $PORTST"
                        eout "{blk_p2p} deny all to/from udp port $PORTST"
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p tcp --sport 1024:65534 --dport $PORTST -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p tcp --sport 1024:65534 --dport $PORTST -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p tcp --dport 1024:65534 --sport $PORTST -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p tcp --dport 1024:65534 --sport $PORTST -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p udp --sport 1024:65534 --dport $PORTST -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p udp --sport 1024:65534 --dport $PORTST -j REJECT
                        if [ "$LOG_DROP" == "1" ]; then
                         ipt -A P2P -p udp --dport 1024:65534 --sport $PORTST -m limit --limit=$LOG_RATE/minute -j $LOG_TARGET --log-level=$LOG_LEVEL $LEXT --log-prefix "** P2P ** "
                        fi
                        ipt -A P2P -p udp --dport 1024:65534 --sport $PORTST -j REJECT
                fi
        done
        ipt -A INPUT -j P2P
        ipt -A OUTPUT -j P2P
fi

if [ "$BLK_TCP_SACK_PANIC" == "1" ] && [ "$SYSCTL_TCP_NOSACK" != "1" ]; then
	eout "{blk_tcp_sack_panic} applying mitigation for TCP SACK Panic CVE-2019-11477, CVE-2019-11478, CVE-2019-11479 https://access.redhat.com/security/vulnerabilities/tcpsack"
	eout "{blk_tcp_sack_panic} deny inbound tcp-flags SYN with MSS size 1 to 500 bytes "
	ipt -I INPUT -p tcp --tcp-flags SYN SYN -m tcpmss --mss 1:500 -j $TCP_STOP
fi
