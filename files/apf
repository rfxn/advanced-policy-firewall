VER="2.0.2"
CNF="/etc/apf/conf.apf"

apf_banner() {
	echo "Advanced Policy Firewall (APF) v$VER <proj@rfxn.com>"
	echo "      Copyright (C) 2002-2026, R-fx Networks <proj@rfxn.com>"
	echo "      Copyright (C) 2026, Ryan MacDonald <ryan@rfxn.com>"
	echo "This program may be freely redistributed under the terms of the GNU GPL v2"
	echo ""
}

if [ -f "$CNF" ]; then
   source "$CNF"
else
   apf_banner
   echo "$CNF not found, aborting." >&2
   exit 1
fi

# Initialize log environment (creates dirs, files, enables output modules)
# ELOG_LOG_DIR/ELOG_AUDIT_FILE are set in internals.conf
if ! elog_init; then
	echo "warning: elog_init failed; structured event logging may be unavailable" >&2
fi
# elog_init enables file/audit_file but NOT stdout — enable it for eout() compat
elog_output_enable "stdout" 2>/dev/null || true  # safe: stdout always registered in elog_lib.sh

if [ ! -f "$LOG_APF" ]; then
        touch "$LOG_APF"
        chmod 640 "$LOG_APF"
        eout "{glob} status log not found, created"
fi

# Clean up mutex lock on unexpected termination
trap '_apf_cleanup_tmp; mutex_unlock' EXIT

# Acquire exclusive lock for mutating operations via file-based flock.
# Re-invokes this script under flock; child sees _APF_LOCKED=1 and skips gate.
# Read-only ops (-l, -t, -o, -v, -g, -h, --templ, --gre-status, --la, --ld, --validate, --rules, --info, --lookup, --cc, --ct-status) excluded.
# Restart (-r) excluded — sub-invocations lock individually to avoid deadlock.
if [ "$_APF_LOCKED" != "1" ]; then
  case "$1" in
    -s|--start|-f|--stop|--flush|-e|--refresh|\
    -a|--allow|-d|--deny|-u|--remove|--unban|\
    -ta|--temp-allow|-td|--temp-deny|\
    --tempf|--temp-flush|--temp-expire|\
    --ipset-update|--gre-up|--gre-down|--cc-update|--ct-scan)
      if command -v flock >/dev/null 2>&1; then
        _APF_LOCKED=1 flock -w "$ENTER_LOCK_TIMEOUT" "$LOCK_FILE" "$0" "$@"
        exit $?
      fi
      ;;
  esac
fi

case "$1" in
-s|--start)
	mutex_lock
	start
	;;
-f|--flush|--stop)
	mutex_lock
	flush
	elog_event "service_state" "info" "APF firewall stopped"
	;;
-l|--list)
	list
	;;
-t|-st|--status)
	status
	;;

-r|--restart)
	$0 --flush || exit $?
	sleep 2
	$0 --start || exit $?
	;;
-a|--allow)
	# Propagate exit code: invalid host, duplicate, or rule failure → exit 1
	cli_trust "TALLOW" "ALLOW" "$ALLOW_HOSTS" "$2" "$3" || exit 1
	;;
-d|--deny)
	# Propagate exit code: invalid host, duplicate, or rule failure → exit 1
	cli_trust "TDENY" "DENY" "$DENY_HOSTS" "$2" "$3" || exit 1
	;;
-u|--remove|--unban)
	if cli_trust_remove "$2"; then
		eout "{trust} removed $2 from trust system"
		if [ "$SET_VERBOSE" != "1" ]; then
			echo "Removed $2 from trust system."
		fi
	else
		eout "{trust} $2 not found in trust system"
		if [ "$SET_VERBOSE" != "1" ]; then
			echo "$2 not found in trust system." >&2
		fi
	fi
	;;
-e|--refresh)
	mutex_lock
	refresh
	;;
-o|--ovars|--dump-config)
	apf_banner
	ovars
	;;
-v|--version)
	echo "$VER"
	;;
--ipset-update)
	if [ "$USE_IPSET" == "1" ]; then
		mutex_lock
		ipset_update
	else
		echo "ipset not enabled (USE_IPSET=0 in conf.apf)"
	fi
	;;
--gre-up)
	if [ "$USE_GRE" == "1" ]; then
		mutex_lock
		gre_init
	else
		echo "GRE tunnels not enabled (USE_GRE=0 in conf.apf)"
	fi
	;;
--gre-down)
	if [ "$USE_GRE" == "1" ]; then
		mutex_lock
		gre_teardown
	else
		echo "GRE tunnels not enabled (USE_GRE=0 in conf.apf)"
	fi
	;;
--gre-status)
	gre_status
	;;
-g|--search)
	search "$2"
	;;
-ta|--temp-allow)
	cli_trust_temp "TALLOW" "ALLOW" "$ALLOW_HOSTS" "$2" "$3" "$4" || exit 1
	;;
-td|--temp-deny)
	cli_trust_temp "TDENY" "DENY" "$DENY_HOSTS" "$2" "$3" "$4" || exit 1
	;;
--templ|--temp-list)
	list_temp_entries
	;;
--tempf|--temp-flush)
	mutex_lock
	flush_temp_entries
	;;
--temp-expire)
	if grep -q '# added .* ttl=' "$ALLOW_HOSTS" "$DENY_HOSTS" "$CC_DENY_HOSTS" "$CC_ALLOW_HOSTS" 2>/dev/null; then
		mutex_lock
		expire_temp_entries
	fi
	;;
-h|--help)
	apf_banner
	help
	;;
--validate|--check)
	cli_validate
	;;
--la|--list-allow)
	list_trust_file "$ALLOW_HOSTS" "allow_hosts.rules"
	;;
--ld|--list-deny)
	list_trust_file "$DENY_HOSTS" "deny_hosts.rules"
	;;
--rules)
	rules
	;;
--info)
	firewall_info
	;;
--lookup)
	trust_lookup "$2" || exit 1
	;;
--ct-scan)
	if ct_enabled; then
		mutex_lock
		# shellcheck disable=SC1090,SC1091
		. "$INSTALL_PATH/internals/ctlimit.apf"
		cli_ct_scan
	else
		echo "CT_LIMIT not enabled (CT_LIMIT=0 in conf.apf)"
	fi
	;;
--ct-status)
	# shellcheck disable=SC1090,SC1091
	. "$INSTALL_PATH/internals/ctlimit.apf"
	cli_ct_status
	;;
--cc)
	# shellcheck disable=SC1090,SC1091
	. "$INSTALL_PATH/internals/geoip.apf"
	geoip_info "$2"
	;;
--cc-update)
	mutex_lock
	# shellcheck disable=SC1090,SC1091
	. "$INSTALL_PATH/internals/geoip.apf"
	geoip_update
	;;
*)
	apf_banner
	help
	exit 1
	;;
esac
mutex_unlock
exit 0
