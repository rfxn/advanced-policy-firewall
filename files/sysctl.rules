eout "{glob} loading sysctl.rules"

# START SYSCTL config

if [ -z "$SYSCTL_CONNTRACK" ]; then
	SYSCTL_CONNTRACK=131072
fi

if [ -f "/proc/sys/net/ipv4/ip_conntrack_max" ]; then
	echo $SYSCTL_CONNTRACK > /proc/sys/net/ipv4/ip_conntrack_max
elif [ -f "/proc/sys/net/nf_conntrack_max" ]; then
	echo $SYSCTL_CONNTRACK > /proc/sys/net/nf_conntrack_max
fi

# Conntrack timeouts: 600s established (default 432000), 90s time-wait (default 120)
if [ -f "/proc/sys/net/netfilter/nf_conntrack_tcp_timeout_established" ]; then
	echo 600 > /proc/sys/net/netfilter/nf_conntrack_tcp_timeout_established
	echo 90 > /proc/sys/net/netfilter/nf_conntrack_tcp_timeout_time_wait
elif [ -f "/proc/sys/net/ipv4/netfilter/ip_conntrack_tcp_timeout_established" ]; then
	echo 600 > /proc/sys/net/ipv4/netfilter/ip_conntrack_tcp_timeout_established
	echo 90 > /proc/sys/net/ipv4/netfilter/ip_conntrack_tcp_timeout_time_wait
fi

# Conntrack hash table sizing
if [ -n "$SYSCTL_CONNTRACK_BUCKETS" ] && [ -f "/sys/module/nf_conntrack/parameters/hashsize" ]; then
	echo "$SYSCTL_CONNTRACK_BUCKETS" > /sys/module/nf_conntrack/parameters/hashsize
fi

# Adaptive conntrack scaling
if [ "$SYSCTL_CONNTRACK_ADAPTIVE" == "1" ] && [ -f "/proc/sys/net/nf_conntrack_count" ]; then
	read ct_current < /proc/sys/net/nf_conntrack_count 2>/dev/null
	read ct_max < /proc/sys/net/nf_conntrack_max 2>/dev/null
	if [ -n "$ct_current" ] && [ -n "$ct_max" ]; then
		ct_threshold=$((ct_max * 80 / 100))
		if [ "$ct_current" -ge "$ct_threshold" ] && [ "$ct_max" -lt "$SYSCTL_CONNTRACK_HIGH" ]; then
			ct_new=$((ct_max + SYSCTL_CONNTRACK_INCREMENT))
			if [ "$ct_new" -gt "$SYSCTL_CONNTRACK_HIGH" ]; then
				ct_new=$SYSCTL_CONNTRACK_HIGH
			fi
			echo "$ct_new" > /proc/sys/net/nf_conntrack_max
			eout "{glob} conntrack_max scaled from $ct_max to $ct_new (current: $ct_current)"
		fi
	fi
fi

# Disable conntrack helpers (ALGs) to reduce attack surface
if [ -f "/proc/sys/net/netfilter/nf_conntrack_helper" ]; then
	echo 0 > /proc/sys/net/netfilter/nf_conntrack_helper
fi

# Unconditional hardening: widen ephemeral port range, ignore bogus ICMP errors
# and ICMP broadcasts (smurf attack mitigation)
echo '24577 65534' > /proc/sys/net/ipv4/ip_local_port_range
echo 1 > /proc/sys/net/ipv4/icmp_ignore_bogus_error_responses
echo 1 > /proc/sys/net/ipv4/icmp_echo_ignore_broadcasts

if [ "$SYSCTL_LOGMARTIANS" == "1" ]; then
	eout "{glob} setting sysctl_logmartians enabled"
	echo 1 > "/proc/sys/net/ipv4/conf/$IFACE_UNTRUSTED/log_martians"
else
        eout "{glob} setting sysctl_logmartians disabled"
        echo 0 > "/proc/sys/net/ipv4/conf/$IFACE_UNTRUSTED/log_martians"
fi

if [ "$SYSCTL_ECN" == "1" ]; then
	eout "{glob} setting sysctl_ecn enabled"
	echo 1 > /proc/sys/net/ipv4/tcp_ecn
else
        eout "{glob} setting sysctl_ecn disabled"
	echo 0 > /proc/sys/net/ipv4/tcp_ecn
fi

if [ "$SYSCTL_SYNCOOKIES" == "1" ]; then
	eout "{glob} setting sysctl_syncookies enabled"
	echo 1 > /proc/sys/net/ipv4/tcp_syncookies
else
        eout "{glob} setting sysctl_syncookies disabled"
	echo 0 > /proc/sys/net/ipv4/tcp_syncookies
fi

if [ "$SYSCTL_OVERFLOW" == "1" ]; then
	eout "{glob} setting sysctl_overflow enabled"
	echo 1 > /proc/sys/net/ipv4/tcp_abort_on_overflow
else
        eout "{glob} setting sysctl_overflow disabled"
        echo 0 > /proc/sys/net/ipv4/tcp_abort_on_overflow
fi

# TCP Parameters
if [ "$SYSCTL_TCP" == "1" ]; then
	eout "{glob} setting sysctl_tcp enabled"
	# tcp_tw_recycle removed in kernel 4.12; only set if proc file exists
	if [ -f "/proc/sys/net/ipv4/tcp_tw_recycle" ]; then
		echo 0 > /proc/sys/net/ipv4/tcp_tw_recycle
	fi
	echo 1 > /proc/sys/net/ipv4/tcp_tw_reuse
	echo 1 > /proc/sys/net/ipv4/tcp_window_scaling
	echo 0 > /proc/sys/net/ipv4/tcp_timestamps
	if [ "$SYSCTL_TCP_NOSACK" == "1" ]; then
		echo 0 > /proc/sys/net/ipv4/tcp_sack
	else
		echo 1 > /proc/sys/net/ipv4/tcp_sack
	fi
        echo 1 > /proc/sys/net/ipv4/tcp_dsack
	# tcp_fack removed in kernel 4.15
	if [ -f "/proc/sys/net/ipv4/tcp_fack" ]; then
		echo 1 > /proc/sys/net/ipv4/tcp_fack
	fi
	echo 1800 > /proc/sys/net/ipv4/tcp_keepalive_time
	echo 30 > /proc/sys/net/ipv4/tcp_fin_timeout
	echo 3 > /proc/sys/net/ipv4/tcp_retries1
fi

# SYN Parameters
if [ "$SYSCTL_SYN" == "1" ]; then
	eout "{glob} setting sysctl_syn enabled"
	echo 2 > /proc/sys/net/ipv4/tcp_synack_retries
	echo 3 > /proc/sys/net/ipv4/tcp_syn_retries
	echo 4096 > /proc/sys/net/ipv4/tcp_max_syn_backlog
fi

# Routing Parameters
if [ "$SYSCTL_ROUTE" == "1" ]; then
	eout "{glob} setting sysctl_routing enabled"
	echo 1 > "/proc/sys/net/ipv4/conf/$IFACE_UNTRUSTED/rp_filter"
	echo 0 > "/proc/sys/net/ipv4/conf/$IFACE_UNTRUSTED/accept_source_route"
	echo 0 > /proc/sys/net/ipv4/conf/all/bootp_relay
	echo 0 > /proc/sys/net/ipv4/ip_forward
	echo 0 > /proc/sys/net/ipv4/conf/all/forwarding
	echo 0 > /proc/sys/net/ipv4/conf/all/accept_redirects
	echo 0 > /proc/sys/net/ipv4/secure_redirects
	echo 0 > /proc/sys/net/ipv4/send_redirects
	echo 0 > /proc/sys/net/ipv4/proxy_arp
fi

echo 1 > /proc/sys/net/ipv4/route/flush

# IPv6 hardening
if [ "$USE_IPV6" == "1" ]; then
	if [ -f "/proc/sys/net/ipv6/conf/all/accept_source_route" ]; then
		echo 0 > /proc/sys/net/ipv6/conf/all/accept_source_route
	fi
	if [ -f "/proc/sys/net/ipv6/conf/all/accept_redirects" ]; then
		echo 0 > /proc/sys/net/ipv6/conf/all/accept_redirects
	fi
	if [ -f "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_source_route" ]; then
		echo 0 > "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_source_route"
	fi
	if [ -f "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_redirects" ]; then
		echo 0 > "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_redirects"
	fi
	if [ "$SYSCTL_ROUTE" == "1" ]; then
		if [ -f "/proc/sys/net/ipv6/conf/all/forwarding" ]; then
			echo 0 > /proc/sys/net/ipv6/conf/all/forwarding
		fi
	fi
	if [ -f "/proc/sys/net/ipv6/conf/all/accept_ra" ]; then
		echo 0 > /proc/sys/net/ipv6/conf/all/accept_ra
	fi
	if [ -f "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_ra" ]; then
		echo 0 > "/proc/sys/net/ipv6/conf/$IFACE_UNTRUSTED/accept_ra"
	fi
	if [ -f "/proc/sys/net/ipv6/route/flush" ]; then
		echo 1 > /proc/sys/net/ipv6/route/flush
	fi
	eout "{glob} setting ipv6 sysctl hardening enabled"
fi

# END SYSCTL config
