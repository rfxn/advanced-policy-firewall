#!/bin/bash
# apf postrm — generated by pkg_gen.sh from pkg_lib templates
#
# Post-remove scriptlet: cleans up symlink farm directory, state, and
# config on purge.
#
# Placeholders:
#   apf          — package name
#   /etc/apf  — legacy install path
#   /usr/local/sbin/fwmgr    — legacy binary path (e.g., /usr/local/sbin/bfd)
#   @@PKG_POSTRM_EXTRA@@  — project-specific post-remove commands (optional)
#
set -e

case "$1" in
    remove)
        # Clean up the symlink farm directory (links are removed by dpkg,
        # but the directory itself and any runtime-created files remain)
        rm -rf /etc/apf 2>/dev/null || true
        rm -f /usr/local/sbin/fwmgr 2>/dev/null || true
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
    purge)
        # Clean up symlink farm
        rm -rf /etc/apf 2>/dev/null || true
        rm -f /usr/local/sbin/fwmgr 2>/dev/null || true
        # Remove config directory on purge
        rm -rf /etc/apf 2>/dev/null || true
        # Remove state
        rm -rf /var/lib/apf 2>/dev/null || true
@@PKG_POSTRM_EXTRA@@
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
