#!/bin/bash
# apf postrm — clean up after package removal
set -e

case "$1" in
    remove)
        # Clean runtime-created files only — conffiles preserved per Debian policy
        command rm -f /etc/cron.d/refresh.apf /etc/cron.d/apf_develmode /etc/cron.d/ctlimit.apf 2>/dev/null || true  # cron files may not exist
        command rm -f /etc/apf/vnet/*.rules 2>/dev/null || true  # generated VNET rules may not exist
        command rm -rf /etc/apf/geoip/ 2>/dev/null || true  # GeoIP cache may not exist
        command rm -rf /var/lib/apf/tmp/* 2>/dev/null || true  # tmp dir may be empty
        # Clean runtime state files (iptables snapshots, change detection, cron templates)
        command rm -f /etc/apf/internals/.apf.restore* /etc/apf/internals/.apf6.restore* 2>/dev/null || true  # IPv4+IPv6 snapshots may not exist
        command rm -f /etc/apf/internals/.apf.input.baseline /etc/apf/internals/.apf.output.baseline 2>/dev/null || true  # baseline files may not exist
        command rm -f /etc/apf/internals/.apf6.input.baseline /etc/apf/internals/.apf6.output.baseline 2>/dev/null || true  # IPv6 baseline files may not exist
        command rm -f /etc/apf/internals/.md5.cores* /etc/apf/internals/.last.vars* 2>/dev/null || true  # change markers may not exist
        command rm -f /etc/apf/internals/.last.full 2>/dev/null || true  # fast-load timestamp may not exist
        command rm -f /etc/apf/internals/.block_history* 2>/dev/null || true  # CT_LIMIT block history may not exist
        command rm -f /etc/apf/internals/.localaddrs /etc/apf/internals/.localaddrs6 /etc/apf/internals/.trusts.md5 2>/dev/null || true  # runtime caches may not exist
        command rm -f /etc/apf/internals/.ct_last_scan /etc/apf/internals/.ipset.timestamps /etc/apf/internals/.gre.tunnels 2>/dev/null || true  # feature state files may not exist
        command rm -f /etc/apf/internals/cron.* 2>/dev/null || true  # runtime cron templates may not exist
        command rm -f /etc/apf/lock.utime 2>/dev/null || true  # lock file may not exist
        command rm -rf /etc/apf/.apf-* 2>/dev/null || true  # temp files/dirs may not exist
        command find /etc/apf/internals/ -maxdepth 1 -type l -delete 2>/dev/null || true  # dir may not exist
        command rm -f /etc/apf/extras /etc/apf/doc 2>/dev/null || true  # symlinks may not exist
        command rm -f /etc/apf/vnet/vnetgen 2>/dev/null || true  # symlink may not exist
        command rm -f /usr/local/sbin/apf /usr/local/sbin/fwmgr 2>/dev/null || true  # compat symlinks may not exist
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true  # systemd may not be running
        fi
        ;;
    purge)
        command rm -rf /etc/apf 2>/dev/null || true  # dir may already be removed
        command rm -rf /var/lib/apf 2>/dev/null || true  # state dir may not exist
        command rm -rf /var/log/apf 2>/dev/null || true  # log dir may not exist
        command rm -f /usr/local/sbin/apf /usr/local/sbin/fwmgr 2>/dev/null || true  # compat symlinks may not exist
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true  # systemd may not be running
        fi
        ;;
esac

#DEBHELPER#

exit 0
