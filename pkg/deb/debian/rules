#!/usr/bin/make -f
# apf Debian rules — generated by pkg_gen.sh from pkg_lib templates
#
#
%:
	dh $@

override_dh_auto_build:
	# Create .pkg copies and sed-transform binary paths
	cp apf.service apf.service.pkg
	sed -i 's|/etc/apf/apf|/usr/sbin/apf|g' apf.service.pkg
	cp apf.init apf.init.pkg
	sed -i -e 's|/etc/apf/apf|/usr/sbin/apf|g' \
	       -e 's|"$$INSTALL_PATH/apf"|"/usr/sbin/apf"|g' apf.init.pkg
	cp cron.d.apf cron.d.apf.pkg
	sed -i 's|/etc/apf/apf|/usr/sbin/apf|g' cron.d.apf.pkg

override_dh_auto_install:
	set -e; \
	DESTDIR=debian/apf; \
	install -D -m 755 files/apf $${DESTDIR}/usr/sbin/apf; \
	install -D -m 640 files/conf.apf $${DESTDIR}/etc/apf/conf.apf; \
	install -D -m 640 files/allow_hosts.rules $${DESTDIR}/etc/apf/allow_hosts.rules; \
	install -D -m 640 files/deny_hosts.rules $${DESTDIR}/etc/apf/deny_hosts.rules; \
	install -D -m 640 files/cc_allow.rules $${DESTDIR}/etc/apf/cc_allow.rules; \
	install -D -m 640 files/cc_deny.rules $${DESTDIR}/etc/apf/cc_deny.rules; \
	install -D -m 750 files/hook_pre.sh $${DESTDIR}/etc/apf/hook_pre.sh; \
	install -D -m 750 files/hook_post.sh $${DESTDIR}/etc/apf/hook_post.sh; \
	install -D -m 640 files/sysctl.rules $${DESTDIR}/etc/apf/sysctl.rules; \
	install -D -m 640 files/sdrop_hosts.rules $${DESTDIR}/etc/apf/sdrop_hosts.rules; \
	install -D -m 640 files/silent_ips.rules $${DESTDIR}/etc/apf/silent_ips.rules; \
	install -D -m 640 files/VERSION $${DESTDIR}/etc/apf/VERSION; \
	for f in glob_allow.rules glob_deny.rules bt.rules log.rules main.rules \
	         ds_hosts.rules ecnshame_hosts.rules gre.rules ipset.rules \
	         preroute.rules postroute.rules; do \
	    install -D -m 640 "files/$$f" "$${DESTDIR}/etc/apf/$$f"; \
	done; \
	install -D -m 640 files/internals/internals.conf $${DESTDIR}/etc/apf/internals/internals.conf; \
	for f in apf.lib.sh apf_core.sh apf_cli.sh apf_ipt.sh apf_trust.sh \
	         apf_validate.sh apf_ipset.sh apf_dlist.sh apf_geoip.sh \
	         apf_ctlimit.sh elog_lib.sh geoip_lib.sh pkg_lib.sh; do \
	    install -D -m 644 "files/internals/$$f" "$${DESTDIR}/usr/lib/apf/internals/$$f"; \
	done; \
	install -D -m 755 files/internals/gretunnel.sh $${DESTDIR}/usr/lib/apf/internals/gretunnel.sh; \
	for f in cports.common icmp.types private.networks reserved.networks \
	         multicast.networks rab.ports; do \
	    install -D -m 644 "files/internals/$$f" "$${DESTDIR}/usr/lib/apf/internals/$$f"; \
	done; \
	install -D -m 755 files/extras/importconf $${DESTDIR}/usr/lib/apf/extras/importconf; \
	install -D -m 755 files/extras/get_ports $${DESTDIR}/usr/lib/apf/extras/get_ports; \
	install -D -m 755 files/vnet/vnetgen $${DESTDIR}/usr/lib/apf/vnet/vnetgen; \
	install -D -m 640 files/vnet/main.vnet $${DESTDIR}/etc/apf/vnet/main.vnet; \
	install -D -m 640 files/vnet/vnetgen.def $${DESTDIR}/etc/apf/vnet/vnetgen.def; \
	install -d -m 750 $${DESTDIR}/var/lib/apf/tmp; \
	install -d -m 750 $${DESTDIR}/etc/apf/geoip; \
	install -d -m 750 $${DESTDIR}/var/log/apf; \
	install -D -m 644 apf.service.pkg $${DESTDIR}/lib/systemd/system/apf.service; \
	install -D -m 755 apf.init.pkg $${DESTDIR}/etc/init.d/apf; \
	install -D -m 644 cron.d.apf.pkg $${DESTDIR}/etc/cron.d/apf; \
	install -D -m 644 logrotate.d.apf $${DESTDIR}/etc/logrotate.d/apf; \
	install -D -m 644 apf.bash-completion $${DESTDIR}/usr/share/bash-completion/completions/apf; \
	install -D -m 644 apf.8 $${DESTDIR}/usr/share/man/man8/apf.8; \
	install -D -m 644 README.md $${DESTDIR}/usr/share/doc/apf/README.md; \
	install -D -m 644 CHANGELOG $${DESTDIR}/usr/share/doc/apf/CHANGELOG; \
	install -D -m 644 FLOW $${DESTDIR}/usr/share/doc/apf/FLOW; \
	install -D -m 644 COPYING.GPL $${DESTDIR}/usr/share/doc/apf/COPYING.GPL; \
	printf '%s\n' \
	    '# pkg_lib:symlink-manifest:1' \
	    '/etc/apf/internals/apf.lib.sh	/usr/lib/apf/internals/apf.lib.sh' \
	    '/etc/apf/internals/apf_core.sh	/usr/lib/apf/internals/apf_core.sh' \
	    '/etc/apf/internals/apf_cli.sh	/usr/lib/apf/internals/apf_cli.sh' \
	    '/etc/apf/internals/apf_ipt.sh	/usr/lib/apf/internals/apf_ipt.sh' \
	    '/etc/apf/internals/apf_trust.sh	/usr/lib/apf/internals/apf_trust.sh' \
	    '/etc/apf/internals/apf_validate.sh	/usr/lib/apf/internals/apf_validate.sh' \
	    '/etc/apf/internals/apf_ipset.sh	/usr/lib/apf/internals/apf_ipset.sh' \
	    '/etc/apf/internals/apf_dlist.sh	/usr/lib/apf/internals/apf_dlist.sh' \
	    '/etc/apf/internals/apf_geoip.sh	/usr/lib/apf/internals/apf_geoip.sh' \
	    '/etc/apf/internals/apf_ctlimit.sh	/usr/lib/apf/internals/apf_ctlimit.sh' \
	    '/etc/apf/internals/elog_lib.sh	/usr/lib/apf/internals/elog_lib.sh' \
	    '/etc/apf/internals/geoip_lib.sh	/usr/lib/apf/internals/geoip_lib.sh' \
	    '/etc/apf/internals/pkg_lib.sh	/usr/lib/apf/internals/pkg_lib.sh' \
	    '/etc/apf/internals/gretunnel.sh	/usr/lib/apf/internals/gretunnel.sh' \
	    '/etc/apf/internals/cports.common	/usr/lib/apf/internals/cports.common' \
	    '/etc/apf/internals/icmp.types	/usr/lib/apf/internals/icmp.types' \
	    '/etc/apf/internals/private.networks	/usr/lib/apf/internals/private.networks' \
	    '/etc/apf/internals/reserved.networks	/usr/lib/apf/internals/reserved.networks' \
	    '/etc/apf/internals/multicast.networks	/usr/lib/apf/internals/multicast.networks' \
	    '/etc/apf/internals/rab.ports	/usr/lib/apf/internals/rab.ports' \
	    '/etc/apf/extras	/usr/lib/apf/extras' \
	    '/etc/apf/doc	/usr/share/doc/apf' \
	    '/etc/apf/vnet/vnetgen	/usr/lib/apf/vnet/vnetgen' \
	    '/usr/local/sbin/apf	/usr/sbin/apf' \
	    '/usr/local/sbin/fwmgr	/usr/sbin/apf' \
	    > $${DESTDIR}/usr/lib/apf/internals/.symlink-manifest

override_dh_installdeb:
	dh_installdeb
	# debhelper-compat=13 auto-detects ALL /etc/ files as conffiles.
	# APF has 28+ files under /etc/ but only 11 are true conffiles
	# (user-editable config). The rest are APF-managed rule templates
	# and symlinks that should receive updates on upgrade without
	# prompting. Replace the auto-generated list with our explicit list.
	#
	# NOTE: verify_farm creates relative symlinks (../usr/lib/...) which
	# triggers 25 pkg_fhs_verify_farm() warnings on first run after DEB
	# install. Self-corrects on first APF startup. Deferred to pkg_lib
	# v1.0.7 — relative vs absolute is a pkg_lib concern, not APF.
	cp debian/apf.conffiles debian/apf/DEBIAN/conffiles

override_dh_auto_test:
	# Skip — tests require privileged Docker environment

override_dh_auto_clean:
	rm -f apf.service.pkg apf.init.pkg cron.d.apf.pkg
	dh_auto_clean
