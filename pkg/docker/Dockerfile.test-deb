# apf DEB install verification — Debian 12
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   apf             — package name
#   (deb test deps)   — runtime dependencies to install before testing
#
FROM debian:12

# Install dependencies that apf requires at runtime
RUN apt-get update && \
    apt-get install -y --no-install-recommends bash coreutils iptables iproute2 kmod sed gawk grep procps && \
    rm -rf /var/lib/apt/lists/*

# Copy DEB and test script from build context
COPY apf_*.deb /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package (use dpkg + apt fix-broken for dependency resolution)
RUN dpkg -i /tmp/apf_*.deb || apt-get install -f -y

CMD ["/test/test-pkg-install.sh", "deb"]
