# apf RPM install verification — Rocky 9
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   apf             — package name
#   (rpm test deps)   — runtime dependencies to install before testing
#
FROM rockylinux:9

# Install dependencies that apf requires at runtime
RUN dnf install -y --allowerasing bash coreutils iptables iproute kmod sed gawk grep procps-ng && \
    dnf clean all

# Copy RPM and test script from build context
COPY apf-*el9*.rpm /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package
RUN rpm -ivh /tmp/apf-*el9*.rpm

CMD ["/test/test-pkg-install.sh", "rpm"]
